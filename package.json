{
  "name": "zerithdb",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "description": "Local-first, peer-to-peer backend platform. The browser is the server.",
  "author": "ZerithDB Contributors",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=20",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=!./apps/* && changeset publish",
    "prepare": "husky && sh scripts/setup-git-config.sh",
    "build:audit": "pnpm --filter zerithdb-audit build",
    "benchmark": "tsx scripts/benchmark.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.7",
    "pouchdb": "^9.0.0",
    "pouchdb-adapter-indexeddb": "^9.0.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  }
}
