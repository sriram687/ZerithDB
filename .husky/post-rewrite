#!/usr/bin/env sh
# .husky/post-rewrite
# Runs after `git rebase` and `git amend` that rewrite commits.
# Keeps node_modules in sync if the lockfile was touched.

command=$1   # "rebase" or "amend"

if [ "$command" = "rebase" ]; then
  if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "pnpm-lock.yaml"; then
    echo "⚙️  pnpm-lock.yaml changed after rebase — running pnpm install..."
    pnpm install
  fi
fi
