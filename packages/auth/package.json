{
  "name": "zerithdb-auth",
  "version": "0.2.0",
  "description": "Public/private key identity management for ZerithDB — no passwords",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./capability/types": {
      "types": "./dist/capability/types.d.ts",
      "import": "./dist/capability/types.js",
      "require": "./dist/capability/types.cjs"
    },
    "./capability/ucan": {
      "types": "./dist/capability/ucan.d.ts",
      "import": "./dist/capability/ucan.js",
      "require": "./dist/capability/ucan.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/capability/index.ts --format esm,cjs --dts --out-dir dist",
    "dev": "tsup src/index.ts src/capability/index.ts --format esm,cjs --dts --watch --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "zerithdb-core": "workspace:*",
    "zerithdb-wasm-crypto": "workspace:*",
    "multiformats": "^13.1.0"
  },
  "devDependencies": {
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "files": [
    "dist",
    "src"
  ]
}