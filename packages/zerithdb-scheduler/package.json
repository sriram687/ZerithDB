{
  "name": "zerithdb-scheduler",
  "version": "0.1.0",
  "description": "Distributed scheduled tasks with leader election for ZerithDB",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zerithdb-core": "workspace:*",
    "zerithdb-network": "workspace:*"
  },
  "devDependencies": {
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4"
  }
}
