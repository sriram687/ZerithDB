{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "downlevelIteration": true,
    "paths": {
      "zerithdb-auth": ["../auth/src/index.ts"],
      "zerithdb-auth/*": ["../auth/src/*"]
    }
  }
}
