{
  "name": "zerithdb-auth-auth0",
  "version": "0.2.0",
  "description": "Auth0 integration for ZerithDB peer identities",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.1.0",
    "zerithdb-auth": "workspace:*",
    "zerithdb-core": "workspace:*"
  },
  "devDependencies": {
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "files": [
    "dist",
    "src"
  ]
}
